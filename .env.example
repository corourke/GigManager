VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Google Calendar Integration
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Error monitoring (optional — Sentry is a no-op when unset)
# Web app DSN from your Sentry project (React)
VITE_SENTRY_DSN=

# Edge functions use SENTRY_DSN / SENTRY_ENVIRONMENT, set via:
#   supabase secrets set SENTRY_DSN=... SENTRY_ENVIRONMENT=development
